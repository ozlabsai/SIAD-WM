{
  "version": "v2",
  "preprocessing_version": "v2",
  "created_at": "2026-03-05T00:00:00Z",
  "git_commit": "pending",
  "feature": "003-temporal-conditioning",
  "description": "Preprocessing configuration for temporal conditioning with month-of-year cyclical encoding",

  "features": {
    "weather": {
      "description": "Weather anomaly features from ERA5 and CHIRPS",
      "fields": [
        {
          "name": "rain_anom",
          "index": 0,
          "type": "float32",
          "units": "dimensionless",
          "source": "CHIRPS monthly precipitation anomaly (z-score)",
          "description": "Precipitation anomaly vs 10-year climatology"
        },
        {
          "name": "temp_anom",
          "index": 1,
          "type": "float32",
          "units": "dimensionless",
          "source": "ERA5 monthly temperature anomaly (z-score)",
          "description": "Temperature anomaly vs climatology"
        }
      ]
    },
    "temporal": {
      "description": "Cyclical temporal features for seasonal context",
      "fields": [
        {
          "name": "month_sin",
          "index": 2,
          "type": "float32",
          "units": "dimensionless",
          "range": [-1, 1],
          "formula": "sin(2π * month / 12)",
          "description": "Sine component of month-of-year cyclical encoding"
        },
        {
          "name": "month_cos",
          "index": 3,
          "type": "float32",
          "units": "dimensionless",
          "range": [-1, 1],
          "formula": "cos(2π * month / 12)",
          "description": "Cosine component of month-of-year cyclical encoding"
        }
      ],
      "invariants": {
        "unit_circle": "month_sin² + month_cos² ≈ 1.0 (within [0.99, 1.01])",
        "year_boundary_continuity": "December→January distance < 0.6"
      }
    }
  },

  "schema": {
    "action_vector": {
      "shape": "[H, 4]",
      "description": "Extended action vector with weather + temporal features",
      "dimensions": {
        "H": "Rollout horizon (typically 6 months)",
        "4": "Feature dimension (2 weather + 2 temporal)"
      }
    },
    "dataset": {
      "format": "manifest.jsonl + GeoTIFF",
      "attributes": {
        "preprocessing_version": "v2",
        "action_dim": 4
      },
      "fields": {
        "observations": "[N, C=8, H=256, W=256] - Satellite imagery",
        "actions": "[N, H, 4] - Extended action vectors",
        "timestamps": "[N, H+1] - Datetime64 for context + rollout"
      }
    }
  },

  "changes_from_v1": {
    "action_shape": {
      "v1": "[H, 2]",
      "v2": "[H, 4]",
      "change": "Added month_sin and month_cos temporal features"
    },
    "timestamp_requirement": {
      "v1": "Optional (not used)",
      "v2": "Required (used to compute temporal features)",
      "change": "Timestamps now required for temporal feature extraction"
    },
    "backward_compatibility": {
      "dataset": "V1 datasets can load in V2 code (timestamps=None, action_dim=2)",
      "model": "V1 checkpoints can load in V2 models (zero-initialized temporal weights)",
      "upgrade_path": "Use add_temporal_features_to_actions() to upgrade v1→v2"
    }
  },

  "validation": {
    "temporal_features": {
      "range_check": "-1 ≤ month_sin, month_cos ≤ 1",
      "unit_circle_check": "0.99 ≤ (month_sin² + month_cos²) ≤ 1.01",
      "year_boundary_check": "Dec→Jan Euclidean distance < 0.6"
    },
    "action_shape": {
      "expected_shape": "[H, 4]",
      "feature_order": ["rain_anom", "temp_anom", "month_sin", "month_cos"]
    }
  },

  "performance_targets": {
    "training_throughput_degradation": "<5%",
    "model_parameter_increase": "128 params (0.0002% of total)",
    "seasonal_transition_false_positive_reduction": ">20%",
    "rollout_error_reduction": ">10% at step 6"
  },

  "usage": {
    "preprocessing": {
      "command": "uv run siad preprocess --config configs/preprocess-v2.yaml"
    },
    "training": {
      "command": "uv run siad train --config configs/train-temporal-v2.yaml"
    },
    "validation": {
      "unit_tests": "uv run pytest tests/unit/test_temporal_features.py",
      "integration_tests": "uv run pytest tests/integration/"
    }
  },

  "references": {
    "spec": "specs/003-003-temporal-conditioning/spec.md",
    "plan": "specs/003-003-temporal-conditioning/plan.md",
    "tasks": "specs/003-003-temporal-conditioning/tasks.md"
  }
}
