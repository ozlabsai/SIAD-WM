      "error": "#ef4444"
    },
    "state": {
      "hover": "rgba(20, 184, 166, 0.1)",
      "active": "rgba(20, 184, 166, 0.2)",
      "selected": "rgba(245, 158, 11, 0.15)",
      "disabled": "rgba(115, 115, 115, 0.1)"
    }
  },
  "typography": {
    "fonts": {
      "mono": "'JetBrains Mono', 'Fira Code', 'Consolas', monospace",
      "ui": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "display": "'Rajdhani', 'Orbitron', sans-serif",
      "tactical": "'Rajdhani', sans-serif"
    },
    "sizes": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "base": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "4xl": "2.25rem",
      "5xl": "3rem"
    },
    "weights": {
      "light": 300,
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "black": 900
    },
    "lineHeights": {
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.75
    },
    "letterSpacing": {
      "tight": "-0.025em",
      "normal": "0",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em"
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "borderRadius": {
    "none": "0",
    "sm": "0.125rem",
    "base": "0.25rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "full": "9999px"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.5)",
    "base": "0 1px 3px 0 rgba(0, 0, 0, 0.6), 0 1px 2px 0 rgba(0, 0, 0, 0.8)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.6), 0 2px 4px -1px rgba(0, 0, 0, 0.8)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.7), 0 4px 6px -2px rgba(0, 0, 0, 0.9)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.8), 0 10px 10px -5px rgba(0, 0, 0, 0.9)",
    "glow-cyan": "0 0 20px rgba(20, 184, 166, 0.5), 0 0 40px rgba(20, 184, 166, 0.2)",
    "glow-amber": "0 0 20px rgba(245, 158, 11, 0.5), 0 0 40px rgba(245, 158, 11, 0.2)"
  },
  "transitions": {
    "fast": "100ms cubic-bezier(0.4, 0, 0.2, 1)",
    "base": "200ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slow": "300ms cubic-bezier(0.4, 0, 0.2, 1)",
    "slower": "500ms cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "zIndex": {
    "base": 0,
    "dropdown": 1000,
    "sticky": 1020,
    "fixed": 1030,
    "modalBackdrop": 1040,
    "modal": 1050,
    "popover": 1060,
    "tooltip": 1070
  },
  "components": {
    "hexButton": {
      "padding": "8px 16px",
      "border": "1px solid #14b8a6",
      "borderRadius": "0",
      "background": "transparent",
      "hover": {
        "background": "rgba(20, 184, 166, 0.1)",
        "shadow": "0 0 20px rgba(20, 184, 166, 0.3)"
      },
      "active": {
        "background": "rgba(245, 158, 11, 0.15)",
        "border": "1px solid #f59e0b",
        "shadow": "0 0 20px rgba(245, 158, 11, 0.4)"
      }
    },
    "panel": {
      "background": "rgba(26, 26, 26, 0.95)",
      "border": "1px solid #262626",
      "borderRadius": "0.5rem",
      "backdropFilter": "blur(8px)",
      "shadow": "0 4px 6px -1px rgba(0, 0, 0, 0.6)"
    },
    "card": {
      "background": "#1a1a1a",
      "border": "1px solid #262626",
      "borderRadius": "0.25rem",
      "hover": {
        "border": "1px solid #14b8a6",
        "shadow": "0 0 15px rgba(20, 184, 166, 0.2)"
      },
      "selected": {
        "background": "rgba(245, 158, 11, 0.1)",
        "border": "1px solid #f59e0b",
        "shadow": "0 0 20px rgba(245, 158, 11, 0.3)"
      }
    },
    "input": {
      "background": "#1a1a1a",
      "border": "1px solid #3f3f3f",
      "borderRadius": "0.25rem",
      "padding": "0.5rem 0.75rem",
      "color": "#f5f5f5",
      "fontSize": "0.875rem",
      "fontFamily": "'JetBrains Mono', monospace",
      "focus": {
        "border": "1px solid #14b8a6",
        "shadow": "0 0 0 2px rgba(20, 184, 166, 0.2)"
      }
    },
    "badge": {
      "padding": "0.125rem 0.5rem",
      "borderRadius": "0.25rem",
      "fontSize": "0.75rem",
      "fontWeight": 600,
      "letterSpacing": "0.05em",
      "textTransform": "uppercase",
      "variants": {
        "success": {
          "background": "rgba(34, 197, 94, 0.15)",
          "color": "#22c55e",
          "border": "1px solid rgba(34, 197, 94, 0.3)"
        },
        "warning": {
          "background": "rgba(245, 158, 11, 0.15)",
          "color": "#f59e0b",
          "border": "1px solid rgba(245, 158, 11, 0.3)"
        },
        "error": {
          "background": "rgba(239, 68, 68, 0.15)",
          "color": "#ef4444",
          "border": "1px solid rgba(239, 68, 68, 0.3)"
        },
        "info": {
          "background": "rgba(20, 184, 166, 0.15)",
          "color": "#14b8a6",
          "border": "1px solid rgba(20, 184, 166, 0.3)"
        }
      }
    },
    "hexTile": {
      "size": "48px",
      "border": "2px solid #14b8a6",
      "background": "rgba(20, 184, 166, 0.05)",
      "borderRadius": "0.375rem",
      "transition": "all 200ms cubic-bezier(0.4, 0, 0.2, 1)",
      "hover": {
        "border": "2px solid #22d3ee",
        "background": "rgba(20, 184, 166, 0.15)",
        "shadow": "0 0 30px rgba(20, 184, 166, 0.4), inset 0 0 20px rgba(20, 184, 166, 0.1)"
      },
      "active": {
        "border": "2px solid #f59e0b",
        "background": "rgba(245, 158, 11, 0.2)",
        "shadow": "0 0 40px rgba(245, 158, 11, 0.5), inset 0 0 25px rgba(245, 158, 11, 0.15)"
      },
      "disabled": {
        "border": "2px solid #525252",
        "background": "rgba(82, 82, 82, 0.05)",
        "opacity": "0.5"
      }
    },
    "timelineScrubber": {
      "height": "48px",
      "background": "linear-gradient(to bottom, rgba(20, 184, 166, 0.1), rgba(20, 184, 166, 0.05))",
      "border": "1px solid #262626",
      "borderRadius": "0.375rem",
      "padding": "0.5rem",
      "thumb": {
        "width": "24px",
        "height": "32px",
        "background": "linear-gradient(135deg, #14b8a6 0%, #0891b2 100%)",
        "border": "1px solid #22d3ee",
        "borderRadius": "0.25rem",
        "shadow": "0 0 15px rgba(20, 184, 166, 0.6), inset 0 0 10px rgba(255, 255, 255, 0.2)"
      },
      "track": {
        "background": "rgba(10, 10, 10, 0.8)",
        "border": "1px solid #3f3f3f",
        "height": "4px"
      },
      "monthLabel": {
        "fontSize": "0.75rem",
        "fontFamily": "'JetBrains Mono', monospace",
        "color": "#d4d4d4",
        "fontWeight": 600
      }
    },
    "climateSlider": {
      "height": "6px",
      "background": "rgba(10, 10, 10, 0.8)",
      "border": "1px solid #262626",
      "borderRadius": "3px",
      "thumb": {
        "width": "20px",
        "height": "20px",
        "background": "radial-gradient(circle, #f59e0b, #d97706)",
        "border": "2px solid #fcd34d",
        "borderRadius": "50%",
        "shadow": "0 0 12px rgba(245, 158, 11, 0.6), inset 0 0 8px rgba(255, 255, 255, 0.3)"
      },
      "variants": {
        "temperature": {
          "trackGradient": "linear-gradient(to right, #0e7490, #f59e0b)"
        },
        "rainfall": {
          "trackGradient": "linear-gradient(to right, #164e63, #14b8a6)"
        }
      }
    },
    "confidenceIndicator": {
      "size": "24px",
      "borderRadius": "50%",
      "border": "2px solid",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "fontSize": "0.75rem",
      "fontWeight": 700,
      "fontFamily": "'JetBrains Mono', monospace",
      "variants": {
        "high": {
          "border": "2px solid #22c55e",
          "background": "rgba(34, 197, 94, 0.15)",
          "color": "#22c55e",
          "shadow": "0 0 10px rgba(34, 197, 94, 0.4)"
        },
        "medium": {
          "border": "2px solid #f59e0b",
          "background": "rgba(245, 158, 11, 0.15)",
          "color": "#f59e0b",
          "shadow": "0 0 10px rgba(245, 158, 11, 0.4)"
        },
        "low": {
          "border": "2px solid #ef4444",
          "background": "rgba(239, 68, 68, 0.15)",
          "color": "#ef4444",
          "shadow": "0 0 10px rgba(239, 68, 68, 0.4)"
        }
      }
    },
    "metricBadge": {
      "padding": "0.375rem 0.75rem",
      "borderRadius": "12px",
      "fontSize": "0.75rem",
      "fontWeight": 600,
      "fontFamily": "'JetBrains Mono', monospace",
      "letterSpacing": "0.05em",
      "textTransform": "uppercase",
      "display": "inline-flex",
      "alignItems": "center",
      "gap": "0.375rem",
      "border": "1px solid",
      "variants": {
        "mse": {
          "background": "rgba(20, 184, 166, 0.12)",
          "color": "#a5f3fc",
          "border": "1px solid rgba(20, 184, 166, 0.4)"
        },
        "psnr": {
          "background": "rgba(245, 158, 11, 0.12)",
          "color": "#fde68a",
          "border": "1px solid rgba(245, 158, 11, 0.4)"
        },
        "ssim": {
          "background": "rgba(34, 197, 94, 0.12)",
          "color": "#86efac",
          "border": "1px solid rgba(34, 197, 94, 0.4)"
        },
        "accuracy": {
          "background": "rgba(139, 92, 246, 0.12)",
          "color": "#d8b4fe",
          "border": "1px solid rgba(139, 92, 246, 0.4)"
        }
      }
    },
    "comparisonToggle": {
      "width": "160px",
      "height": "40px",
      "borderRadius": "0.375rem",
      "background": "#0a0a0a",
      "border": "1px solid #262626",
      "padding": "0.25rem",
      "display": "flex",
      "gap": "0.25rem",
      "segment": {
        "flex": 1,
        "borderRadius": "0.25rem",
        "fontSize": "0.75rem",
        "fontWeight": 600,
        "fontFamily": "'JetBrains Mono', monospace",
        "textTransform": "uppercase",
        "color": "#737373",
        "background": "transparent",
        "border": "none",
        "transition": "all 200ms cubic-bezier(0.4, 0, 0.2, 1)",
        "cursor": "pointer"
      },
      "segmentActive": {
        "background": "linear-gradient(135deg, rgba(20, 184, 166, 0.2), rgba(34, 211, 238, 0.1))",
        "color": "#a5f3fc",
        "border": "1px solid rgba(20, 184, 166, 0.5)",
        "shadow": "0 0 15px rgba(20, 184, 166, 0.3), inset 0 0 8px rgba(20, 184, 166, 0.1)"
      }
    }
  },
  "grid": {
    "columns": 12,
    "gutter": "1.5rem",
    "margin": "2rem"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  }
}
